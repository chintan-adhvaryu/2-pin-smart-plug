#define BLYNK_TEMPLATE_ID "BLYNK_TEMPLATE_ID"
#define BLYNK_TEMPLATE_NAME "BLYNK_TEMPLATE_NAME"
#define BLYNK_AUTH_TOKEN    "BLYNK_AUTH_TOKEN"

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <WebServer.h>

char ssid[] = "Phone_EXT";
char pass[] = "12123434";

WebServer server(80);

const int relay1 = 26;
const int relay2 = 27;

// --- BLYNK SYNC LOGIC ---

// This function runs every time the ESP32 connects to Blynk Cloud
BLYNK_CONNECTED() {
  Serial.println("Connected to Blynk! Syncing states...");
  // This tells the cloud to send the latest values of V1 and V2 to the ESP32
  Blynk.syncVirtual(V1, V2);
}

// Handler for Relay 1
BLYNK_WRITE(V1) {
  int value = param.asInt(); 
  // 1 = ON (Low signal for relay), 0 = OFF (High signal)
  digitalWrite(relay1, value == 1 ? LOW : HIGH);
  Serial.print("Relay 1 changed to: ");
  Serial.println(value == 1 ? "ON" : "OFF");
}

// Handler for Relay 2
BLYNK_WRITE(V2) {
  int value = param.asInt();
  digitalWrite(relay2, value == 1 ? LOW : HIGH);
  Serial.print("Relay 2 changed to: ");
  Serial.println(value == 1 ? "ON" : "OFF");
}

// --- LOCAL WEB SERVER ---

void handleRoot() {
  String html = "<html><head><meta name='viewport' content='width=device-width, initial-scale=1'></head>";
  html += "<body style='font-family:sans-serif; text-align:center;'>";
  html += "<h1>Smart Plug Active</h1>";
  html += "<p>Connected to Blynk Cloud</p>";
  html += "<p>Use your Dashboard HTML file to control and set timers.</p>";
  html += "</body></html>";
  server.send(200, "text/html", html);
}

void setup() {
  Serial.begin(115200);
  
  pinMode(relay1, OUTPUT);
  pinMode(relay2, OUTPUT);
  
  // Start with Relays OFF for safety
  digitalWrite(relay1, HIGH); 
  digitalWrite(relay2, HIGH);

  // Initialize Blynk (This also handles the WiFi connection)
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  server.on("/", handleRoot);
  server.begin();
  Serial.println("Web server started");
}

void loop() {
  Blynk.run();
  server.handleClient();
}
